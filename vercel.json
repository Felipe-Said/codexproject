{
  "functions": {
    "api/*.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/protection-settings",
      "destination": "/api/protection-settings.js"
    },
    {
      "source": "/api/save-order",
      "destination": "/api/save-order.js"
    },
    {
      "source": "/api/checkout-config",
      "destination": "/api/checkout-config.js"
    },
    {
      "source": "/api/create-checkout-session",
      "destination": "/api/create-checkout-session.js"
    },
    {
      "source": "/api/order",
      "destination": "/api/order.js"
    },
    {
      "source": "/api/confirm-order",
      "destination": "/api/confirm-order.js"
    }
  ]
}
